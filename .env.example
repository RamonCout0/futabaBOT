# ── Futaba Sakura · Configuração de Ambiente ──────────────────
# Copie este arquivo para .env e preencha os valores.
# No ShardCloud, defina como variáveis de ambiente no painel.

# Token do bot (obrigatório)
DISCORD_TOKEN=seu_token_aqui

# Diretório de dados (opcional, padrão: ./data)
DATA_DIR=data
